{
  "version": 2,
  "buildCommand": "cd frontend && npm install --legacy-peer-deps && npm run build && cd ../backend && pip install -r ../api/requirements.txt && python manage.py collectstatic --noinput",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.py": {
      "runtime": "python3.12",
      "maxDuration": 30,
      "includeFiles": "backend/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*",    "destination": "/api/index.py" },
    { "source": "/admin/:path*",  "destination": "/api/index.py" },
    { "source": "/static/:path*", "destination": "/api/index.py" },
    { "source": "/media/:path*",  "destination": "/api/index.py" },
    {
      "source": "/((?!api|admin|static|media).*)",
      "destination": "/index.html"
    }
  ]
}
